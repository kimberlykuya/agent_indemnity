# Arc execution path currently used by the backend
ARC_RPC_URL=https://rpc.arc.network
ARC_CHAIN_ID=5042002
DEPLOYER_PRIVATE_KEY=your_deployer_wallet_pk
AGENT_WALLET_ADDRESS=0x...
VICTIM_WALLET_ADDRESS=0x...
USDC_CONTRACT_ADDRESS=0x...
PERFORMANCE_BOND_ADDRESS=0x...

# Reserved for planned Circle Gateway integration.
# These values are documented in the repo, but the live FastAPI request path
# does not currently use them to charge end users.
CIRCLE_API_KEY=your_circle_api_key
CIRCLE_WALLET_SET_ID=your_wallet_set_id
CIRCLE_ENTITY_SECRET=your_entity_secret

# Reserved for planned x402 / Gateway integration.
# These are not the active request-payment rail in the current backend.
X402_FACILITATOR_URL=https://...
GATEWAY_API_KEY=your_gateway_key

# AI
GEMINI_API_KEY=your_gemini_api_key
FEATHERLESS_API_KEY=your_featherless_api_key
FEATHERLESS_GENERAL_MODEL=verified_live_model_id
FEATHERLESS_TECH_MODEL=verified_live_model_id
FEATHERLESS_LEGAL_MODEL=verified_live_model_id
GEMINI_ROUTER_MODEL=gemini-3-flash-preview
GEMINI_FALLBACK_MODEL=gemini-3.1-pro-preview
GEMINI_ACTION_MODEL=gemini-3-flash-preview

# Frontend / app runtime
FASTAPI_PORT=8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_ARC_EXPLORER_TX_BASE_URL=https://testnet.arcscan.app/tx

# Slash payout configuration used by the current backend.
# Payouts are sent to AUTO_SLASH_VICTIM_ADDRESS when set, otherwise
# VICTIM_WALLET_ADDRESS is used as the fallback recipient.
# AUTO_SLASH_ON_FLAGGED is documented for planned gating but is not currently
# enforced by the backend runtime.
AUTO_SLASH_ON_FLAGGED=true
AUTO_SLASH_PAYOUT_USDC=1.0
AUTO_SLASH_MIN_PAYOUT_USDC=0.01
AUTO_SLASH_VICTIM_ADDRESS=0x...

# Reserved demo placeholders. These names are currently not read by the
# application runtime.
DEMO_BOND_FALLBACK=true
DEMO_BOND_INITIAL_BALANCE_USDC=1.0
